# ============================================
# FaceAuth Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================

# --- Base de données PostgreSQL (Railway) ---
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/faceauth

# --- Redis (Railway ou Upstash) ---
REDIS_URL=redis://localhost:6379

# --- Sécurité JWT (Challenge Tokens) ---
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_super_secret_key_here
JWT_ALGORITHM=HS256
CHALLENGE_TOKEN_EXPIRE_SECONDS=90

# --- DeepFace ---
DEEPFACE_MODEL=Facenet512
# Options : Facenet512, ArcFace, VGG-Face

# --- CORS (origines autorisées pour le SDK web) ---
# En production, liste les domaines de vos clients SDK
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","https://timothy-tired-iii-sold.trycloudflare.com"]

# --- Seuil de similarité biométrique ---
# Entre 0 et 1 — 0.80 est un point de départ plus strict pour limiter les faux positifs MVP
SIMILARITY_THRESHOLD=0.80
MIN_LIVENESS_TOTAL_MS=1800
MIN_LIVENESS_STEP_MS=500
REQUIRE_LIVENESS_ATTESTATION=True
STRICT_FACE_DETECTION=True
MIN_IMAGE_BRIGHTNESS=18
MAX_IMAGE_BRIGHTNESS=245
MIN_IMAGE_BLUR_VARIANCE=8

# --- Rate limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Environnement ---
ENVIRONMENT=development
# Options : development, production
